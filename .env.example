GROQ_API_KEY=your_groq_api_key_here
SARVAM_API_KEY=your_sarvam_api_key_here
HA_URL=http://192.168.x.x:8123
HA_TOKEN=your_home_assistant_long_lived_access_token_here
# Swiggy Builders Club — OAuth 2.1 access token (leave blank if not using Swiggy)
SWIGGY_ACCESS_TOKEN=

# LiveKit — calling module (leave blank to disable)
# Sign up at livekit.io → Dashboard → Settings → API Keys
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Dashboard → SIP → Trunks → create an outbound trunk, paste the trunk ID here
LIVEKIT_SIP_TRUNK_ID=
# Base URL of this server — used by calling_agent.py to post call results back
CALLING_AGENT_CALLBACK_BASE=http://localhost:8000
